BSC_RPC="https://bsc-dataseed.bnbchain.org"

# Optional integrator config. Both must be set or both unset. 100 bps = 1%
INTEGRATOR_ADDRESS=
INTEGRATOR_FEE_BPS=

# Slack alerting (errors / warnings / trade fills / reviews). Incoming webhook URL.
SLACK_WEBHOOK=

# === Trading bot + dashboard ===
# SAFETY: dry-run by default (no real txs). Set false to enable real trading.
DRY_RUN=true
# The single market the bot trades.
TARGET_MARKET=0x38D8CA35d8662b2c6C94199497d787c93Aa34fEE
# Seconds between trading cycles.
BOT_INTERVAL=300
# Slack market-volume update cadence (default 30 min) and portfolio review (1 h).
MARKET_INTERVAL=1800
PORTFOLIO_INTERVAL=3600
# State persistence (positions, PnL, per-wallet armed flag). Mount a volume in prod.
BOT_STATE_PATH=bot-state.json
BOT_CONFIG_PATH=strategy.config.json
REST_BASE=https://rest.ft.42.space

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=4242
# Password to access the dashboard. LEAVE BLANK ONLY for local dev — set it in prod.
DASHBOARD_PASSWORD=
# Optional: secret for signing session cookies (defaults to DASHBOARD_PASSWORD).
DASHBOARD_SESSION_SECRET=
DASHBOARD_SESSION_SECONDS=43200

# --- Wallets (you fill these in; never commit real keys) ---
# Each wallet is WALLET_<n>_KEY (0x + 64 hex) and optional WALLET_<n>_LABEL.
# All wallets start SAFE (disarmed); arm them in the dashboard to let the bot trade.
WALLET_1_KEY=
WALLET_1_LABEL=Main
# WALLET_2_KEY=
# WALLET_2_LABEL=Alt
